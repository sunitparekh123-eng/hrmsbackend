# ═══════════════════════════════════════════════════════
#  HRMS Backend — Environment Variables Template
#  Copy this file to .env and fill in your actual values
#  NEVER commit .env to git!
# ═══════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1

# ── Database (Railway MySQL) ─────────────────────────────
# Get these values from Railway → your MySQL service → Connect tab
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_NAME=railway
DB_USER=root
DB_PASSWORD=your_railway_password
DB_DIALECT=mysql
DB_LOGGING=false
DB_SYNC_FORCE=false
DB_SYNC_ALTER=true   # Set to true ONLY on first deploy, then false
DB_SSL=false         # Set to false for local Hostinger MySQL, true for cloud providers

# ── JWT ──────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Add your Render admin panel URL here after deploying
CORS_ORIGIN=https://your-admin-panel.onrender.com,http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ── Timezone ────────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ── Storage (Local) ──────────────────────────────────────
# Files are stored locally in the backend/uploads directory

# ── SMTP / Email (Brevo) ─────────────────────────────────
# https://app.brevo.com → SMTP & API → SMTP tab
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_brevo_smtp_login@smtp-brevo.com
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM=no-reply@yourdomain.com

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=info

# ── Google Maps (optional — for office geofencing) ───────
GOOGLE_MAPS_API_KEY=your_google_maps_key